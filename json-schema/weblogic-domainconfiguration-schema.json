{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/DomainConfiguration",
  "title": "DomainConfiguration",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Domain name"
    },
    "adminServerName": {
      "type": "string",
      "description": "Name of the administration server"
    },
    "domainVersion": {
      "type": "string",
      "description": "WebLogic Server domain version"
    },
    "productionModeEnabled": {
      "type": "boolean",
      "description": "Whether the domain is in production mode"
    },
    "configurationVersion": {
      "type": "string",
      "description": "Configuration version string"
    },
    "links": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/Link"
      }
    }
  }
}