{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/JMSSystemResource",
  "title": "JMSSystemResource",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "JMS system resource name"
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Target servers or clusters"
    },
    "descriptorFileName": {
      "type": "string",
      "description": "JMS descriptor file name"
    },
    "links": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/Link"
      }
    }
  },
  "required": [
    "name"
  ]
}