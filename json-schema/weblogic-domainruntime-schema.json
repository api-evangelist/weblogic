{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/DomainRuntime",
  "title": "DomainRuntime",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Domain name"
    },
    "activationTime": {
      "type": "integer",
      "format": "int64",
      "description": "Domain activation time in milliseconds"
    },
    "links": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/Link"
      }
    }
  }
}