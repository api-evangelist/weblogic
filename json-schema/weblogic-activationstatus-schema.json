{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ActivationStatus",
  "title": "ActivationStatus",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "description": "Status of the activation",
      "enum": [
        "ACTIVATED",
        "FAILED",
        "PENDING"
      ]
    },
    "activationTasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "server": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        }
      }
    }
  }
}